# Ignore everything by default
*

# Allow specific top-level files
!run.bat
!run.sh
!How to run.md

# Allow src folder and contents
!src/
!src/**

# Ignore compiled Java class files
src/**/*.class

# Allow bin folder itself
!bin/

# Ignore everything inside bin
bin/**

# Allow a placeholder so bin folder stays tracked
!bin/.gitkeep
